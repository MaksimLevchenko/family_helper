# Copy this file to config/passwords.yaml and fill in real secrets per environment.
# Do not commit config/passwords.yaml.

shared:
  mySharedPassword: 'replace-me'

development:
  database: 'replace-me'
  redis: 'replace-me'
  serviceSecret: 'replace-me'
  emailSecretHashPepper: 'replace-me'
  jwtHmacSha512PrivateKey: 'replace-me'
  jwtRefreshTokenHashPepper: 'replace-me'
  minioEndpoint: 'localhost:9000'
  minioBucket: 'family-helper'
  minioSecretKey: 'replace-me'
  minioPublicBaseUrl: 'http://localhost:9000'
  minioUseSsl: 'false'
  minioSignUrlTtl: '900'

